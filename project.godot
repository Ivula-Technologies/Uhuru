; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Uhuru: Eyes of the Land"
run/main_scene="res://scenes/menus/TitleScreen.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

SaveGame="*res://scripts/save/save_game.gd"
QuestManager="*res://scripts/quests/quest_manager.gd"
InventoryManager="*res://scripts/inventory/inventory_manager.gd"
TimeOfDay="*res://scripts/systems/time_of_day.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"
ChapterManager="*res://scripts/systems/chapter_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/size/resizable=true
window/size/min_width=960
window/size/min_height=540

